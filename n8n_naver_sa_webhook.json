    "네이버 API - 캠페인": { "main": [[{ "node": "Stats 메시지 준비", "type": "main", "index": 0 }]] },
    "Stats 메시지 준비": { "main": [[{ "node": "HMAC 서명 (Stats)", "type": "main", "index": 0 }]] },
    "HMAC 서명 (Stats)": { "main": [[{ "node": "Stats 서명 합치기", "type": "main", "index": 0 }]] },
    "Stats 서명 합치기": { "main": [[{ "node": "네이버 API - Stats", "type": "main", "index": 0 }]] },
    "네이버 API - Stats": { "main": [[{ "node": "데이터 조합", "type": "main", "index": 0 }]] },
    "데이터 조합": { "main": [[{ "node": "응답 반환", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" }
}
